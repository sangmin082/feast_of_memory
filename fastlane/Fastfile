# 기억의 만찬 — TestFlight 배포 레인
#
# 필요한 GitHub Secrets (repo Settings → Secrets and variables → Actions):
#   APP_STORE_CONNECT_KEY_ID / APP_STORE_CONNECT_ISSUER_ID / APP_STORE_CONNECT_KEY(p8 base64)
#   APPLE_TEAM_ID / MATCH_GIT_URL / MATCH_GIT_BASIC_AUTHORIZATION / MATCH_PASSWORD

require "base64"

default_platform(:ios)

BUNDLE_ID = "com.feastofmemory.game"
XCODEPROJ = "FeastOfMemory.xcodeproj"

platform :ios do
  desc "빌드 후 TestFlight 업로드"
  lane :beta do
    setup_ci # CI용 임시 키체인 생성

    # Secrets는 base64 인코딩/원문 어느 쪽이든 허용
    p8 = ENV.fetch("APP_STORE_CONNECT_KEY").strip
    p8_is_base64 = !p8.include?("BEGIN PRIVATE KEY")

    basic_auth = ENV["MATCH_GIT_BASIC_AUTHORIZATION"].to_s.strip
    if basic_auth.include?(":") # "계정:PAT" 원문으로 등록한 경우 자동 인코딩
      ENV["MATCH_GIT_BASIC_AUTHORIZATION"] = Base64.strict_encode64(basic_auth)
    end

    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_KEY_ID").strip,
      issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID").strip,
      key_content: p8,
      is_key_content_base64: p8_is_base64
    )

    # 배포 인증서 + 프로비저닝 프로파일 생성/동기화 (인증서 저장 repo 사용)
    match(
      type: "appstore",
      app_identifier: BUNDLE_ID,
      git_url: ENV.fetch("MATCH_GIT_URL"),
      api_key: api_key,
      readonly: false
    )

    profile_name = ENV.fetch("sigh_#{BUNDLE_ID}_appstore_profile-name")

    update_code_signing_settings(
      path: XCODEPROJ,
      use_automatic_signing: false,
      team_id: ENV.fetch("APPLE_TEAM_ID"),
      code_sign_identity: "Apple Distribution",
      bundle_identifier: BUNDLE_ID,
      profile_name: profile_name
    )

    build_app(
      project: XCODEPROJ,
      scheme: "FeastOfMemory",
      configuration: "Release",
      export_method: "app-store",
      # 빌드 번호 = GitHub Actions 실행 번호 (업로드마다 자동 증가)
      xcargs: "CURRENT_PROJECT_VERSION=#{ENV.fetch('GITHUB_RUN_NUMBER', '1')}"
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
